# Copy to .env and fill in values. .env is gitignored.

# Database (PostgreSQL or SQLite for local dev)
DATABASE_URL=sqlite:///polymarket.db
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# SSL mode for PostgreSQL (require, verify-ca, verify-full, prefer, disable)
# Default: require (for Railway / production). Set to "disable" for local dev without SSL.
DATABASE_SSLMODE=disable

# Polymarket API
POLYMARKET_CLOB_API=https://clob.polymarket.com
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com

# PMXT archive
PMXT_ARCHIVE_URL=https://archive.pmxt.dev

# Fee (basis points, 30 = 0.3%)
DEFAULT_FEE_BPS=30

# API rate limit (requests per minute for PolymarketClient)
API_RATE_LIMIT=100

# Collector: interval in seconds (900 = 15 min)
COLLECT_INTERVAL_SEC=900

# Server port (Railway sets PORT automatically)
PORT=8000

# Trading: dry run (true = simulation, false = real orders)
POLYMARKET_DRY_RUN=true

# For real trading — leave empty for simulation
# POLYMARKET_PRIVATE_KEY=
# POLYMARKET_PASSPHRASE=

# News collector: keywords (comma-separated)
NEWS_KEYWORDS=election,trump,biden,market,polymarket

# RSS feeds (comma-separated URLs, empty = default Google News)
# RSS_FEEDS=
