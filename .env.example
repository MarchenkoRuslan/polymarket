# Copy to .env and fill in values. .env is gitignored.

# Database (PostgreSQL or SQLite for local dev)
DATABASE_URL=sqlite:///polymarket.db
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# SSL mode for PostgreSQL (require, verify-ca, verify-full, prefer, disable)
# Default: require (for Railway / production). Set to "disable" for local dev without SSL.
DATABASE_SSLMODE=disable

# Polymarket API
POLYMARKET_CLOB_API=https://clob.polymarket.com
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com

# CLOB authentication (enables real trade data with buy/sell sides)
# Generate via py-clob-client: client.create_or_derive_api_creds()
# If only PRIVATE_KEY is set, API creds are auto-derived on startup.
# POLYMARKET_PRIVATE_KEY=0x...
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=

# PMXT archive
PMXT_ARCHIVE_URL=https://archive.pmxt.dev

# Fee (basis points, 30 = 0.3%)
DEFAULT_FEE_BPS=30

# API rate limit (requests per minute for PolymarketClient)
API_RATE_LIMIT=100

# Collector: interval in seconds (3600 = 1 hour, avoids flooding DB with duplicates)
COLLECT_INTERVAL_SEC=3600

# Defer first pipeline run by seconds (HTTP ready before heavy API calls)
COLLECT_DEFER_SEC=5

# Skip ML and backtest on first pipeline run (true = faster dashboard data, full run next cycle)
SKIP_ML_FIRST_RUN=true

# Max markets to collect detailed data per cycle (0 = all liquid)
COLLECT_MARKETS_LIMIT=0

# Minimum volume to consider a market "liquid" (skip low-liquidity markets)
MIN_MARKET_VOLUME=1000

# ML target horizon (predict price up within next N periods instead of next 1)
ML_TARGET_HORIZON=5

# Minimum price std dev to train ML on a market (skip flat-price markets)
MIN_PRICE_STD=0.002

# Server port (Railway sets PORT automatically)
PORT=8000

# Trading: dry run (true = simulation, false = real orders)
POLYMARKET_DRY_RUN=true

# For real trading — leave empty for simulation
# POLYMARKET_PRIVATE_KEY=
# POLYMARKET_PASSPHRASE=

# News collector: keywords (comma-separated)
NEWS_KEYWORDS=election,trump,biden,market,polymarket

# RSS feeds (comma-separated URLs, empty = default Google News)
# RSS_FEEDS=

# CORS: allowed origins for Web App (comma-separated, * = all)
CORS_ORIGINS=*

# Telegram bot (opens polymarket-ui Web App in Telegram)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# WEBAPP_URL=https://your-ui-domain.com
